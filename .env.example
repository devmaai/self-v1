# TinaCMS Cloud credentials — get these from app.tina.io after creating a project.
# See BLOG-CMS-SETUP.md for step-by-step instructions.

# Public project ID (safe to expose to the browser).
NEXT_PUBLIC_TINA_CLIENT_ID=

# Content (Read-only) token from Tina Cloud → Tokens → New Token (Type:
# "Content (Read-only)", Git Branches: main). The site only READS with this;
# editor saves are authorized per logged-in user, not by this token.
# SECRET — set in Vercel env vars, never commit a real value.
TINA_TOKEN=

# Branch the CMS reads/writes. Leave as main unless you use a different branch.
NEXT_PUBLIC_TINA_BRANCH=main

# ── Audit form (/api/audit) ─────────────────────────────────────────────
# Resend API key — get one free at https://resend.com (API Keys → Create).
# SECRET — set in Vercel env vars, never commit a real value.
RESEND_API_KEY=

# Where audit submissions are delivered. Defaults to business@maai.agency.
AUDIT_TO_EMAIL=business@maai.agency

# From address. "onboarding@resend.dev" works immediately with no domain setup.
# Once you verify your domain in Resend, switch to e.g. "audit@selfstorage.help".
AUDIT_FROM_EMAIL=SelfStorage Audit <onboarding@resend.dev>

# Cloudflare Turnstile captcha keys — free at
# https://dash.cloudflare.com → Turnstile → Add site.
# If both are left blank, the captcha widget is hidden and skipped (dev mode).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
